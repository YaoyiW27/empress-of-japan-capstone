# Copy to .env for local development. .env is git-ignored — never commit real secrets.
#
# Local dev database from docker-compose (backend/docker-compose.yml).
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/empress

# Deployed ECS tasks receive DB_HOST, DB_PORT, DB_NAME, DB_USER, and DB_PASSWORD
# from Secrets Manager. Do not copy RDS credentials or DATABASE_URL values into
# GitHub, chat, or developer files.

# Optional overrides
# APP_ENV=local
# LOG_LEVEL=info
# CHAT_MODEL=stub
# BEDROCK_CHAT_MODEL=us.anthropic.claude-sonnet-4-6
# PERSONA_DIR=../data/ai/personas
# SCENE_DIR=../data/ai/scenes

# Async ingest worker (AWS SQS, or local SQS-compatible endpoint)
# JOBS_QUEUE_URL=http://localhost:4566/000000000000/empress-jobs
# SQS_ENDPOINT_URL=http://localhost:4566
# SQS_WAIT_TIME_SECONDS=20
# SQS_MAX_MESSAGES=1
# INGEST_ADMIN_TOKEN=change-me
# INGEST_JOB_EXTERNAL_PATH=external_sources.json
# INGEST_JOB_CSV_PATH=
# INGEST_JOB_CLASSIFIED_PATH=

# Voice interaction (AWS credentials come from the ECS task role / local AWS profile)
# VOICE_CACHE_BUCKET=
# VOICE_CACHE_PREFIX=polly-cache/
# POLLY_ENGINE=neural
# TRANSCRIBE_LANGUAGE_CODE=en-US
# VOICE_AUDIO_URL_TTL_SECONDS=900
# VOICE_MAX_TEXT_LENGTH=1000

# OpenTelemetry tracing
# OTEL_ENABLED=false
# OTEL_SERVICE_NAME=empress-backend
# OTEL_EXPORTER_OTLP_ENDPOINT=http://127.0.0.1:4318/v1/traces
# OTEL_RESOURCE_ATTRIBUTES=deployment.environment=local

# Copy to .env for local development. .env is git-ignored — never commit real secrets.
#
# Local dev database from docker-compose (backend/docker-compose.yml).
# The cloud database is AWS RDS (infra/ track) — point this at the RDS endpoint
# there, sourced from a secret manager, never hardcoded.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/empress

# Optional overrides
# APP_ENV=local
# LOG_LEVEL=info
# CHAT_MODEL=stub
# BEDROCK_CHAT_MODEL=us.anthropic.claude-sonnet-4-6

# OpenTelemetry tracing
# OTEL_ENABLED=true
# OTEL_SERVICE_NAME=empress-backend
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
# OTEL_RESOURCE_ATTRIBUTES=deployment.environment=local

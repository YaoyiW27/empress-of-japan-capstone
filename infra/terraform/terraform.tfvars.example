# Example variable overrides for the infra/terraform root module.
#
# Copy to terraform.tfvars to override defaults locally. Real *.tfvars files are
# gitignored — never commit one. The defaults already target the sandbox, so you
# normally don't need this file at all.

# region       = "us-west-2"
# canary_value = "bootstrap-verified-by-yaoyi"

# --- Cost tracking (issue #20) ---
# The defaults in variables.tf already target the team + $1000 budget, so you
# normally don't need to override these. Examples:
# monthly_budget_limit  = 1000
# budget_thresholds     = [20, 50, 80]   # ACTUAL-spend alerts (%)
# forecasted_thresholds = [50, 80]       # FORECASTED-spend early warnings (%)
# alert_emails          = ["wang.yaoyi@northeastern.edu"]
